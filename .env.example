# ============================================================================
# PocketCV — Variables de entorno (plantilla)
# Copia este archivo a .env y rellena los valores reales.
# ============================================================================

# --- Base de datos (MySQL) ---
# Debe coincidir con docker-compose.yml
POCKETCV_DATABASE_URL="mysql://pocketcv:pocketcvpass@localhost:3307/pocketcv"
MYSQL_ROOT_PASSWORD="rootpass"
MYSQL_DATABASE="pocketcv"
MYSQL_USER="pocketcv"
MYSQL_PASSWORD="pocketcvpass"

# --- Better-Auth ---
# Secreto para firmar sesiones. Genera uno con: npx @better-auth/cli@latest secret
BETTER_AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# URL pública donde corre la app
BETTER_AUTH_URL="http://localhost:3000"

# --- M2: AI Interview Agent (DeepSeek) ---
# API key de DeepSeek. Necesaria para el agente de entrevista conversacional.
DEEPSEEK_API_KEY="sk-..."
# Modelo de DeepSeek (por defecto: deepseek-chat).
DEEPSEEK_MODEL="deepseek-chat"


